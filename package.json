{
  "name": "sentinel-asm",
  "version": "1.0.0",
  "private": true,
  "description": "SENTINEL-ASM — 권한 검증 기반 엔터프라이즈 공격표면관리/취약점 점검/컴플라이언스 플랫폼",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:web": "esbuild web/app.js --bundle --format=esm --minify --outfile=public/app.js",
    "dev": "npm run build:web && tsx watch src/index.ts",
    "start": "npm run build:web && tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1",
    "htm": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "esbuild": "^0.23.1",
    "jsdom": "^24.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
